# ----------------------------------------------------------------------------
# aiomtec2mqtt — example environment overrides
# ----------------------------------------------------------------------------
# Copy to `.env` and source it, or export the variables directly in your
# shell / systemd unit. Every variable with the prefix `MTEC_` overrides the
# matching key in `config.yaml` at runtime.
#
#   MTEC_<CONFIG_KEY>=<value>
#
# Values are parsed as bool / int / float when possible, else kept as string.
# ----------------------------------------------------------------------------

# --- Modbus (M-TEC Energybutler) --------------------------------------------
# MTEC_MODBUS_IP=espressif.fritz.box
# MTEC_MODBUS_PORT=502
# MTEC_MODBUS_SLAVE=247
# MTEC_MODBUS_TIMEOUT=5
# MTEC_MODBUS_RETRIES=3
# MTEC_MODBUS_FRAMER=socket

# --- MQTT broker ------------------------------------------------------------
# MTEC_MQTT_SERVER=localhost
# MTEC_MQTT_PORT=1883
# MTEC_MQTT_LOGIN=mqtt-user
# MTEC_MQTT_PASSWORD=change-me
# MTEC_MQTT_TOPIC=MTEC
# MTEC_MQTT_FLOAT_FORMAT={:.3f}

# --- Refresh intervals (seconds) --------------------------------------------
# MTEC_REFRESH_NOW=10
# MTEC_REFRESH_DAY=300
# MTEC_REFRESH_TOTAL=300
# MTEC_REFRESH_CONFIG=30
# MTEC_REFRESH_STATIC=3600

# --- Home Assistant ---------------------------------------------------------
# MTEC_HASS_ENABLE=false
# MTEC_HASS_BASE_TOPIC=homeassistant
# MTEC_HASS_BIRTH_GRACETIME=15

# --- General ----------------------------------------------------------------
# MTEC_DEBUG=false
